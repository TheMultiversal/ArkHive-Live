{
  "ollama": {
    "model": "llama3.1:8b",
    "temperature": 0.75,
    "timeout": 120000,
    "maxConcurrent": 2
  },
  "workers": {
    "min": 4,
    "max": 6,
    "heartbeatTimeout": 120000,
    "taskTimeout": 180000,
    "restartCooldown": 2000
  },
  "scanner": {
    "scanInterval": 45000,
    "quickScanInterval": 10000,
    "maxProfilesPerCycle": 200,
    "maxQueueSize": 2000
  },
  "generation": {
    "mode": "hybrid",
    "batchSize": 20,
    "backupBeforeInject": true,
    "cooldownBetweenBatches": 1000,
    "maxProfilesPerSession": 5000,
    "enrichExisting": true
  },
  "replication": {
    "enabled": true,
    "maxSpawnedBots": 6
  },
  "monitor": {
    "httpPort": 3001,
    "enableDashboard": true
  },
  "quality": {
    "scoreThreshold": 75,
    "minControversies": 3,
    "minSources": 3,
    "minKnownAssociates": 2,
    "minTimelineEvents": 5,
    "minDescriptionLength": 300
  }
}
